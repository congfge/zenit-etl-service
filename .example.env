PORT=3666
API_VERSION="v1"
OPENAI_API_KEY="YOUR_KEY"

# Token para proteger endpoints de mutación (X-Internal-Token header)
INTERNAL_API_SECRET=your-secret-here

# --- SQL Server (fuente ETL + promotores — cuenta solo lectura) ---
SQLSERVER_USER=SQLSERVER_USER
SQLSERVER_PASSWORD=SQLSERVER_PASSWORD
SQLSERVER_HOST=SQLSERVER_HOST
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=DBI_ECODIGITAL
SQLSERVER_DRIVER="ODBC Driver 18 for SQL Server"
SQLSERVER_POOL_SIZE=5
SQLSERVER_POOL_MAX_OVERFLOW=10
SQLSERVER_POOL_TIMEOUT=30
SQLSERVER_POOL_RECYCLE=3600

# --- PostgreSQL (destino — acceso escritura solo a tablas ETL) ---
# Dev: apunta a base de datos local
# Prod: apunta a 172.17.40.7 (ver .env.prod)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=POSTGRES_USER
POSTGRES_PASSWORD=POSTGRES_PASSWORD
POSTGRES_DATABASE=zenit_db

POSTGRES_ETL_TABLE=creditos_historico_etl

CHUNK_SIZE=10000

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=540

# --- DB2 / IBM i AS400 (solo lectura — fuente de sectores cuando se habilite el conector) ---
# Driver JDBC: com.ibm.as400.access.AS400JDBCDriver
# URL JDBC: jdbc:as400://{host};libraries={database};
DB2_HOST=DB2_HOST
DB2_PORT=446
DB2_USER=DB2_USER
DB2_PASSWORD=DB2_PASSWORD
DB2_DATABASE=DB2_DATABASE
JT400_JAR_PATH=/ruta/al/jt400.jar

# --- Sectores CSV (fuente temporal hasta habilitar DB2) ---
SECTORES_CSV_PATH=/ruta/al/archivo/sectores.csv
